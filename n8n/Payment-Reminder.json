        "html": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\" />\n  <title>Payment Reminder</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 0;\n      padding: 0;\n    }\n    .container {\n      background-color: #ffffff;\n      padding: 40px;\n      border-radius: 8px;\n    }\n    h1 {\n      text-align: center;\n      font-size: 20px;\n      font-weight: bold;\n      margin-bottom: 40px;\n    }\n    .field {\n      font-size: 12px;\n      text-align: left;\n      margin: 8px 0;\n    }\n    .footer {\n      position: absolute;\n      bottom: 20px;\n      width: 100%;\n      text-align: left;\n      font-size: 10px;\n      font-style: italic;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <h1>Payment Reminder</h1>\n\n    <div class=\"field\">To: {{ $json['Client Name'] }}</div>\n    <div class=\"field\">Service/Item: {{ $json['Service/Item'] }}</div>\n    <div class=\"field\">Amount Due: {{ $json.Amount }}</div>\n    <div class=\"field\">Due Date: {{ $json['Due Date'] }}</div>\n\n    <div class=\"footer\">Turbo Tech</div>\n  </div>\n</body>\n</html>"
